generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SAAS_ADMIN
  SCHOOL_ADMIN
  TEACHER
  PARENT
  STUDENT
}

enum ActivityStatus {
  PENDING
  DELIVERED
  LATE
}

enum OccurrenceType {
  WARNING
  SUSPENSION
  NOTICE
  PRAISE
}

model School {
  id          String   @id @default(uuid())
  name        String
  cnpj        String   @unique
  plan        String
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  classes     Class[]
  students    Student[]
  teachers    Teacher[]
  parents     Parent[]
  subjects    Subject[]
  activities  Activity[]
  absences    Absence[]
  grades      Grade[]
  exams       Exam[]
  occurrences Occurrence[]
  refreshTokens RefreshToken[]
  auditLogs   AuditLog[]

  @@index([active])
}

model User {
  id              String    @id @default(uuid())
  schoolId        String?
  name            String
  email           String    @unique
  passwordHash    String
  role            UserRole
  active          Boolean   @default(true)
  lastAccessAt    DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  school          School?   @relation(fields: [schoolId], references: [id])
  parent          Parent?
  student         Student?
  teacher         Teacher?
  notifications   Notification[]
  refreshTokens   RefreshToken[]
  audits          AuditLog[]

  @@index([schoolId, role])
  @@index([role, active])
}

model RefreshToken {
  id         String   @id @default(uuid())
  schoolId   String?
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime @default(now())

  school     School?  @relation(fields: [schoolId], references: [id])
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([schoolId])
}

model Parent {
  id        String    @id @default(uuid())
  schoolId  String
  userId    String    @unique
  phone     String
  createdAt DateTime  @default(now())

  school    School    @relation(fields: [schoolId], references: [id])
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  students  Student[]

  @@index([schoolId])
}

model Teacher {
  id          String     @id @default(uuid())
  schoolId    String
  userId      String     @unique
  createdAt   DateTime   @default(now())

  school      School     @relation(fields: [schoolId], references: [id])
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  subjects    Subject[]
  absences    Absence[]
  grades      Grade[]
  activities  Activity[]
  exams       Exam[]

  @@index([schoolId])
}

model Class {
  id          String     @id @default(uuid())
  schoolId    String
  name        String
  year        Int
  createdAt   DateTime   @default(now())

  school      School     @relation(fields: [schoolId], references: [id])
  students    Student[]
  subjects    Subject[]
  activities  Activity[]
  exams       Exam[]

  @@index([schoolId, year])
}

model Student {
  id           String       @id @default(uuid())
  schoolId     String
  userId       String       @unique
  parentId     String
  classId      String
  registration String
  birthDate    DateTime
  createdAt    DateTime     @default(now())

  school       School       @relation(fields: [schoolId], references: [id])
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent       Parent       @relation(fields: [parentId], references: [id])
  class        Class        @relation(fields: [classId], references: [id])
  grades       Grade[]
  absences     Absence[]
  occurrences  Occurrence[]

  @@unique([schoolId, registration])
  @@index([schoolId, classId])
}

model Subject {
  id          String      @id @default(uuid())
  schoolId    String
  name        String
  classId     String
  teacherId   String
  createdAt   DateTime    @default(now())

  school      School      @relation(fields: [schoolId], references: [id])
  class       Class       @relation(fields: [classId], references: [id])
  teacher     Teacher     @relation(fields: [teacherId], references: [id])
  grades      Grade[]
  absences    Absence[]
  activities  Activity[]
  exams       Exam[]

  @@index([schoolId, classId])
}

model Grade {
  id         String    @id @default(uuid())
  schoolId   String
  studentId  String
  subjectId  String
  teacherId  String
  examId     String?
  value      Float
  term       String
  createdAt  DateTime  @default(now())

  school     School    @relation(fields: [schoolId], references: [id])
  student    Student   @relation(fields: [studentId], references: [id])
  subject    Subject   @relation(fields: [subjectId], references: [id])
  teacher    Teacher   @relation(fields: [teacherId], references: [id])
  exam       Exam?     @relation(fields: [examId], references: [id])

  @@index([schoolId, studentId])
  @@index([schoolId, subjectId, term])
}

model Absence {
  id         String    @id @default(uuid())
  schoolId   String
  studentId  String
  subjectId  String
  teacherId  String
  date       DateTime
  reason     String?

  school     School    @relation(fields: [schoolId], references: [id])
  student    Student   @relation(fields: [studentId], references: [id])
  subject    Subject   @relation(fields: [subjectId], references: [id])
  teacher    Teacher   @relation(fields: [teacherId], references: [id])

  @@index([schoolId, studentId, date])
}

model Activity {
  id          String         @id @default(uuid())
  schoolId    String
  title       String
  description String
  dueDate     DateTime
  status      ActivityStatus @default(PENDING)
  classId     String
  subjectId   String
  teacherId   String
  createdAt   DateTime       @default(now())

  school      School         @relation(fields: [schoolId], references: [id])
  class       Class          @relation(fields: [classId], references: [id])
  subject     Subject        @relation(fields: [subjectId], references: [id])
  teacher     Teacher        @relation(fields: [teacherId], references: [id])

  @@index([schoolId, classId, dueDate])
}

model Exam {
  id          String    @id @default(uuid())
  schoolId    String
  title       String
  date        DateTime
  description String?
  classId     String
  subjectId   String
  teacherId   String
  createdAt   DateTime  @default(now())

  school      School    @relation(fields: [schoolId], references: [id])
  class       Class     @relation(fields: [classId], references: [id])
  subject     Subject   @relation(fields: [subjectId], references: [id])
  teacher     Teacher   @relation(fields: [teacherId], references: [id])
  grades      Grade[]

  @@index([schoolId, classId, date])
}

model Occurrence {
  id          String         @id @default(uuid())
  schoolId    String
  studentId   String
  type        OccurrenceType
  description String
  createdById String
  createdAt   DateTime       @default(now())

  school      School         @relation(fields: [schoolId], references: [id])
  student     Student        @relation(fields: [studentId], references: [id])

  @@index([schoolId, studentId, createdAt])
}

model Notification {
  id         String   @id @default(uuid())
  userId     String
  title      String
  message    String
  type       String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read, createdAt])
}

model AuditLog {
  id          String   @id @default(uuid())
  schoolId    String?
  userId      String?
  action      String
  module      String
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  school      School?  @relation(fields: [schoolId], references: [id])
  user        User?    @relation(fields: [userId], references: [id])

  @@index([schoolId, module, createdAt])
  @@index([userId, createdAt])
}
